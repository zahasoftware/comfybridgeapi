@page "/workflows/test/{id}"
@model ComfyBridge.Api.Pages.Workflows.TestModel
@{
    ViewData["Title"] = "Test Template";
}

<style>
    .page-wrap { margin: 1.5rem; }
    .container { max-width: 980px; margin: 0 auto; }
    .card { background: #fff; border-radius: 12px; padding: 1rem; box-shadow: 0 10px 24px rgba(2,6,23,.08); margin-bottom: 1rem; }
    .grid { display: grid; grid-template-columns: 1fr 120px 1fr; gap: .8rem; align-items: end; }
    .muted { color: #6b7280; }
    .field-label { font-size: .85rem; font-weight: 600; margin-bottom: .2rem; display: block; }
    input { width: 100%; border: 1px solid #cbd5e1; border-radius: 8px; padding: .5rem; }
    .btn { border: 0; border-radius: 8px; padding: .55rem .9rem; cursor: pointer; font-weight: 600; text-decoration: none; display: inline-block; }
    .btn-primary { background: #0f766e; color: #fff; }
    .btn-light { background: #e2e8f0; color: #0f172a; }
    .error { background: #fee2e2; color: #991b1b; padding: .6rem .8rem; border-radius: 8px; }
    .ok { background: #dcfce7; color: #166534; padding: .6rem .8rem; border-radius: 8px; }
    pre { background: #0f172a; color: #e2e8f0; padding: .8rem; border-radius: 10px; overflow-x: auto; }
    @@media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
</style>

<div class="page-wrap">
    <div class="container">
        <div class="card">
            <h1>Test Template: @Model.TemplateName:@Model.TemplateVersion</h1>
            <p class="muted">Run a quick generation job with sample inputs before using this template in production calls.</p>
            <a href="/workflows" class="btn btn-light">Back to templates</a>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="card error">@Model.ErrorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.JobId))
        {
            <div class="card ok">
                Job queued successfully. Job Id: <strong>@Model.JobId</strong> | Status: <strong>@Model.JobStatus</strong>
                <div>
                    <a href="/api/v1/jobs/@Model.JobId">Open job status endpoint</a>
                </div>
            </div>
        }

        <form method="post" asp-page-handler="Execute" class="card">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TemplateName" />
            <input type="hidden" asp-for="TemplateVersion" />

            <h2>Inputs</h2>
            @for (var i = 0; i < Model.Inputs.Count; i++)
            {
                <div class="grid" style="margin-bottom: .8rem;">
                    <div>
                        <label class="field-label">Input Name</label>
                        <input asp-for="Inputs[i].Name" readonly />
                    </div>
                    <div>
                        <label class="field-label">Type</label>
                        <input asp-for="Inputs[i].Type" readonly />
                    </div>
                    <div>
                        <label class="field-label">Value</label>
                        <input asp-for="Inputs[i].Value" />
                    </div>
                </div>
            }

            <button type="submit" class="btn btn-primary">Execute Test Run</button>
        </form>

        <div class="card">
            <h2>curl Example (Windows)</h2>
            <pre>@Model.WindowsCurlExample</pre>
        </div>

        <div class="card">
            <h2>curl Example (bash)</h2>
            <pre>@Model.BashCurlExample</pre>
        </div>
    </div>
</div>
