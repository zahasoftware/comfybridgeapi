@page "/workflows/{id}"
@model ComfyBridge.Api.Pages.Workflows.DetailsModel
@{
    ViewData["Title"] = "Workflow Review";
}

<style>
    .page-wrap { margin: 1.5rem; }
    .container { max-width: 1100px; margin: 0 auto; }
    .card { background: #fff; border-radius: 12px; padding: 1rem; box-shadow: 0 10px 24px rgba(2,6,23,.08); margin-bottom: 1rem; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    label { font-size: .9rem; font-weight: 600; display: block; margin-bottom: .25rem; }
    input, textarea { width: 100%; border: 1px solid #cbd5e1; border-radius: 8px; padding: .55rem; }
    textarea { min-height: 260px; font-family: Consolas, monospace; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid #e5e7eb; padding: .5rem; text-align: left; }
    .chip { display: inline-block; margin: .2rem .2rem 0 0; background: #ecfeff; color: #164e63; border-radius: 999px; padding: .15rem .45rem; font-size: .8rem; }
    .btn { border: 0; border-radius: 8px; padding: .55rem .9rem; cursor: pointer; }
    .btn-primary { background: #0284c7; color: #fff; }
    .btn-light { background: #e2e8f0; color: #0f172a; text-decoration: none; display: inline-block; }
    .error { background: #fee2e2; color: #991b1b; padding: .6rem .8rem; border-radius: 8px; }
    @@media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
</style>

<div class="page-wrap">
<div class="container">
    <div class="card">
        <h1>Review Template</h1>
        <p>Adjust names and mapping before saving to disk.</p>
        <a href="/workflows" class="btn btn-light">Back to list</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="card error">@Model.ErrorMessage</div>
    }

    <form method="post" asp-page-handler="Save" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="WorkflowJson" />
        <input type="hidden" asp-for="DraftId" />
        <input type="hidden" asp-for="IsDraft" />

        <div class="card grid">
            <div>
                <label asp-for="Name">Template Name</label>
                <input asp-for="Name" />
            </div>
            <div>
                <label asp-for="Version">Version</label>
                <input asp-for="Version" />
            </div>
        </div>

        <div class="card">
            <h2>Detected Node Types</h2>
            @if (Model.DetectedNodeTypes.Count == 0)
            {
                <span class="chip">No node types detected</span>
            }
            else
            {
                @foreach (var nodeType in Model.DetectedNodeTypes)
                {
                    <span class="chip">@nodeType</span>
                }
            }
        </div>

        <div class="card">
            <h2>Input Mapping</h2>
            <table>
                <thead>
                    <tr>
                        <th>Input Name</th>
                        <th>Type</th>
                        <th>Node Id</th>
                        <th>Node Class</th>
                        <th>Index</th>
                        <th>Field</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Inputs.Count; i++)
                    {
                        <tr>
                            <td><input asp-for="Inputs[i].InputName" /></td>
                            <td><input asp-for="Inputs[i].InputType" /></td>
                            <td><input asp-for="Inputs[i].NodeId" /></td>
                            <td><input asp-for="Inputs[i].NodeClass" /></td>
                            <td><input asp-for="Inputs[i].NodeIndex" /></td>
                            <td><input asp-for="Inputs[i].Field" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card">
            <h2>Raw Workflow JSON</h2>
            <textarea readonly>@Model.WorkflowJson</textarea>
        </div>

        <div class="card">
            <button type="submit" class="btn btn-primary">Save Template</button>
        </div>
    </form>
</div>
</div>