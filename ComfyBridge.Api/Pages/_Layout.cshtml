<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - ComfyBridge Workflow Manager</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { font-size: 16px; }
        body { font-family: "Segoe UI", sans-serif; background: #f8fafc; color: #111827; line-height: 1.5; }
        a { color: #0284c7; text-decoration: none; }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    @RenderBody()
</body>
</html>
