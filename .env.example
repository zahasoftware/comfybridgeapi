# Docker Compose host port for ComfyBridge API
# Host: http://localhost:5180 -> Container: 8080
COMFYBRIDGE_API_PORT=5180

# ComfyUI endpoint reachable from inside the container
COMFYUI_BASE_URL=http://host.docker.internal:8189

# AI endpoint reachable from inside the container
WORKFLOW_AI_ENDPOINT=http://host.docker.internal:11434